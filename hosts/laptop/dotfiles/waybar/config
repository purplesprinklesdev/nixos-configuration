{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,
  "margin-bottom": 4,
  "margin-top": 4,
  "margin-right": 400,
  "margin-left": 400,

  "modules-left": [
    "sway/workspaces",
    "tray",
    "bluetooth",
    "mpd"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "power-profiles-daemon",
    "backlight",
    "battery",
    "custom/power"
  ],
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
    "format-disconnected": "Disconnected ΎΑΒ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
    "unknown-tag": "N/A",
    "interval": 5,
    "consume-icons": {
      "on": "ΎΔΕ "
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
      "on": "ΎΒ┤ "
    },
    "repeat-icons": {
      "on": "ΎΑη "
    },
    "single-icons": {
      "on": "ΎΑη1 "
    },
    "state-icons": {
      "paused": "ΎΒΝ",
      "playing": "ΎΒΜ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%A, %B %d, %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% ≤░ΓΕ",
    "format-plugged": "{capacity}% ΎΘο",
    "format-alt": "{time} {icon}",
    "format-icons": ["≤░ΓΟ", "≤░Β╗", "≤░Β╛", "≤░ΓΒ", "≤░Β╣"]
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    }
  },
  "network": {
    "format-wifi": "ΎΘτ",
    "format-ethernet": "Ό╜Ε",
    "tooltip-format": "{ifname} via {gwaddr}",
    "format-linked": "{ifname} (No IP)",
    "format-disconnected": "έγι",
    "on-click": "pkill blueman; pkill pavucontrol; pkill nmtui || alacritty --class nmwui -e nmtui"
  },
  "bluetooth": {
    "format": " {status}",
    "format-disabled": "≤░Γ▓",
    "format-off": "≤░Γ▓",
    "format-on": "≤░Γψ",
    "format-connected": "≤░Γ▒ {device_alias}",
    "format-connected-battery": "≤░Γ▒ {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "pkill nmtui; pkill pavucontrol; pkill blueman || blueman-manager",
    "on-click-right": "blueman-applet",
    "on-scroll-up": "bluetoothctl power on",
    "on-scroll-down": "bluetoothctl power off",
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "{icon}ΎΛΦ",
    "format-bluetooth-muted": "{icon}ΎΛΦ",
    "format-muted":"≤░ζθ",
    "format-icons": {
      "headphone": "ΏθΟπ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
	"≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"
      ]
    },
    "on-click": "pkill nmtui; pkill blueman; pkill pavucontrol || pavucontrol"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% ≤░Δθ",
    "scroll-step": 0.5,
    "tooltip": false
  },
  "custom/power": {
    "format": "έΠ╗",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "$HOME/.sysflake/shared/power_menu.xml",
    "menu-actions": {
      "lock": "$HOME/.sysflake/shared/lockman.sh",
      "shutdown": "shutdown -h now",
      "suspend": "systemctl suspend-then-hibernate",
      "reboot": "reboot"
    }
  }
}
